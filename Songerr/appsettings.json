{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
    },
    "Console": {
      "IncludeScopes": false,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
    },
    "File": {
      "Path": "Logs/log-.txt",
      "Append": "true",
      "IncludeScopes": false,
      "TimestampFormat": "yyyyMMddHHmmss"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "Youtube": {
      "ApiKey": "ApiKey",
      "AppName": "Songerr"
    },
    "Spotify": {
      "ClientId": "ClientId",
      "ClientSecret": "ClientSecret"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5002"
      },
      "Https": {
        "Url": "https://localhost:5003"
      }
    }
  },
  "ApiKeys": {
    "MyApiKey": "ApiKey"
  },
  "Songerr": {
    "MaxResults": 1
  }
}
